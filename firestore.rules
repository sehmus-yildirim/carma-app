rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function changedOnlyNestedMapKey(field, key) {
      return request.resource.data
        .get(field, {})
        .diff(resource.data.get(field, {}))
        .affectedKeys()
        .hasOnly([key]);
    }

    function isValidInitialSearchCredit(userId, creditId) {
      return isOwner(userId)
        && creditId == 'main'
        && request.resource.data.userId == userId
        && request.resource.data.used == 0
        && request.resource.data.limit == 2
        && request.resource.data.remaining == 2
        && request.resource.data.paidCredits == 0
        && request.resource.data.totalAvailableRequests == 2
        && request.resource.data.resetPeriod == 'monthly'
        && request.resource.data.periodKey is string;
    }

    function isValidContactRequestCreate() {
      return isSignedIn()
        && request.resource.data.senderUserId == request.auth.uid
        && request.resource.data.receiverUserId is string
        && request.resource.data.receiverUserId != request.auth.uid
        && request.resource.data.targetUserId == request.resource.data.receiverUserId
        && request.resource.data.plateKey is string
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.isDeleted == false;
    }

    function isValidContactRequestAccept(requestId) {
      return resource.data.status == 'pending'
        && request.auth.uid == resource.data.receiverUserId
        && request.resource.data.status == 'accepted'
        && request.resource.data.chatId == 'request_' + requestId
        && request.resource.data.updatedAt is timestamp
        && changedOnly(['status', 'updatedAt', 'chatId']);
    }

    function isValidContactRequestDecline() {
      return resource.data.status == 'pending'
        && request.auth.uid == resource.data.receiverUserId
        && request.resource.data.status == 'declined'
        && request.resource.data.updatedAt is timestamp
        && changedOnly(['status', 'updatedAt']);
    }

    function isValidContactRequestWithdraw() {
      return resource.data.status == 'pending'
        && request.auth.uid == resource.data.senderUserId
        && request.resource.data.status == 'withdrawn'
        && request.resource.data.updatedAt is timestamp
        && changedOnly(['status', 'updatedAt']);
    }

    function isValidContactRequestUpdate(requestId) {
      return isSignedIn()
        && (
          isValidContactRequestAccept(requestId) ||
          isValidContactRequestDecline() ||
          isValidContactRequestWithdraw()
        );
    }

    function isValidChatCreateForRequest(chatId, requestId) {
      let contactRequest = get(/databases/$(database)/documents/contact_requests/$(requestId));

      return isSignedIn()
        && chatId == 'request_' + requestId
        && contactRequest.data.status == 'pending'
        && request.auth.uid == contactRequest.data.receiverUserId
        && request.resource.data.requestId == requestId
        && request.resource.data.status == 'active'
        && request.resource.data.isDeleted == false
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && contactRequest.data.senderUserId in request.resource.data.participants
        && contactRequest.data.receiverUserId in request.resource.data.participants
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          request.resource.data.lastMessage == null ||
          request.resource.data.lastMessage is string
        )
        && (
          request.resource.data.lastMessageAt == null ||
          request.resource.data.lastMessageAt is timestamp
        );
    }

    function isChatParticipant(chatId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function hasValidLastMessageFields() {
      return (
          request.resource.data.lastMessage == null ||
          (
            request.resource.data.lastMessage is string &&
            request.resource.data.lastMessage.size() <= 1000
          )
        )
        && (
          request.resource.data.lastMessageAt == null ||
          request.resource.data.lastMessageAt is timestamp
        )
        && request.resource.data.updatedAt is timestamp;
    }

    function hasValidCurrentUserReadAt() {
      return request.resource.data.lastReadAtBy is map
        && request.resource.data.lastReadAtBy[request.auth.uid] is timestamp
        && changedOnlyNestedMapKey('lastReadAtBy', request.auth.uid);
    }

    function isValidChatLastMessageUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && resource.data.status == 'active'
        && (
          (
            changedOnly(['lastMessage', 'lastMessageAt', 'updatedAt'])
            && hasValidLastMessageFields()
          ) ||
          (
            changedOnly([
              'lastMessage',
              'lastMessageAt',
              'lastReadAtBy',
              'updatedAt',
            ])
            && hasValidLastMessageFields()
            && hasValidCurrentUserReadAt()
          )
        );
    }

    function isValidChatReadUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && resource.data.status == 'active'
        && changedOnly(['lastReadAtBy'])
        && hasValidCurrentUserReadAt();
    }

    function isValidChatTypingUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && resource.data.status == 'active'
        && changedOnly(['typingBy', 'typingUpdatedAtBy'])
        && request.resource.data.typingBy is map
        && request.resource.data.typingBy[request.auth.uid] is bool
        && request.resource.data.typingUpdatedAtBy is map
        && request.resource.data.typingUpdatedAtBy[request.auth.uid] is timestamp
        && changedOnlyNestedMapKey('typingBy', request.auth.uid)
        && changedOnlyNestedMapKey('typingUpdatedAtBy', request.auth.uid);
    }

    function isValidChatFavoriteUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && resource.data.status == 'active'
        && changedOnly(['favoriteBy', 'favoriteUpdatedAtBy', 'updatedAt'])
        && request.resource.data.favoriteBy is map
        && request.resource.data.favoriteBy[request.auth.uid] is bool
        && request.resource.data.favoriteUpdatedAtBy is map
        && request.resource.data.favoriteUpdatedAtBy[request.auth.uid] is timestamp
        && request.resource.data.updatedAt is timestamp
        && changedOnlyNestedMapKey('favoriteBy', request.auth.uid)
        && changedOnlyNestedMapKey('favoriteUpdatedAtBy', request.auth.uid);
    }

    function isValidChatMutedUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && resource.data.status == 'active'
        && changedOnly(['mutedBy', 'mutedUpdatedAtBy', 'updatedAt'])
        && request.resource.data.mutedBy is map
        && request.resource.data.mutedBy[request.auth.uid] is bool
        && request.resource.data.mutedUpdatedAtBy is map
        && request.resource.data.mutedUpdatedAtBy[request.auth.uid] is timestamp
        && request.resource.data.updatedAt is timestamp
        && changedOnlyNestedMapKey('mutedBy', request.auth.uid)
        && changedOnlyNestedMapKey('mutedUpdatedAtBy', request.auth.uid);
    }

    function isValidChatArchiveUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && resource.data.status == 'active'
        && changedOnly(['status', 'updatedAt'])
        && request.resource.data.status == 'archived'
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidChatDeleteUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && resource.data.status == 'active'
        && changedOnly(['status', 'isDeleted', 'updatedAt'])
        && request.resource.data.status == 'deleted'
        && request.resource.data.isDeleted == true
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidChatBlockUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && resource.data.status == 'active'
        && changedOnly(['status', 'blockedBy', 'blockedAt', 'updatedAt'])
        && request.resource.data.status == 'blocked'
        && request.resource.data.blockedBy == request.auth.uid
        && request.resource.data.blockedAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidTextMessageCreate(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));

      return isSignedIn()
        && request.auth.uid in chat.data.participants
        && chat.data.status == 'active'
        && request.resource.data.chatId == chatId
        && request.resource.data.senderUserId == request.auth.uid
        && request.resource.data.type == 'text'
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.isDeleted == false;
    }

    function isValidMessageStarUpdate(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));

      return isSignedIn()
        && request.auth.uid in chat.data.participants
        && chat.data.status == 'active'
        && changedOnly(['isStarred', 'updatedAt'])
        && request.resource.data.isStarred is bool
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidMessageDeleteUpdate(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));

      return isSignedIn()
        && request.auth.uid in chat.data.participants
        && chat.data.status == 'active'
        && resource.data.isDeleted == false
        && changedOnly(['isDeleted', 'updatedAt'])
        && request.resource.data.isDeleted == true
        && request.resource.data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;

      match /profiles/{profileId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if false;
      }

      match /search_credits/{creditId} {
        allow read: if isOwner(userId);
        allow create: if isValidInitialSearchCredit(userId, creditId);
        allow update, delete: if false;
      }

      match /legal_consents/{consentId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /moderation_actions/{actionId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    match /plates/{plateId} {
      allow read, list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.isActive == true
        && request.resource.data.isDeleted == false;

      allow update: if isSignedIn()
        && resource.data.ownerUserId == request.auth.uid
        && request.resource.data.ownerUserId == request.auth.uid;

      allow delete: if false;
    }

    match /contact_requests/{requestId} {
      allow read: if isSignedIn()
        && (
          resource.data.senderUserId == request.auth.uid ||
          resource.data.receiverUserId == request.auth.uid
        );

      allow create: if isValidContactRequestCreate();

      allow update: if isValidContactRequestUpdate(requestId);

      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if request.resource.data.requestId is string
        && isValidChatCreateForRequest(chatId, request.resource.data.requestId);

      allow update: if isValidChatLastMessageUpdate()
        || isValidChatReadUpdate()
        || isValidChatTypingUpdate()
        || isValidChatFavoriteUpdate()
        || isValidChatMutedUpdate()
        || isValidChatArchiveUpdate()
        || isValidChatDeleteUpdate()
        || isValidChatBlockUpdate();

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);

        allow create: if isValidTextMessageCreate(chatId);

        allow update: if isValidMessageStarUpdate(chatId)
          || isValidMessageDeleteUpdate(chatId);

        allow delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read, update, delete: if false;

      allow create: if isSignedIn()
        && request.resource.data.reporterUserId == request.auth.uid;
    }

    match /verification_requests/{requestId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
