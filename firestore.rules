rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function isValidInitialSearchCredit(userId, creditId) {
      return isOwner(userId)
        && creditId == 'main'
        && request.resource.data.userId == userId
        && request.resource.data.used == 0
        && request.resource.data.limit == 2
        && request.resource.data.remaining == 2
        && request.resource.data.paidCredits == 0
        && request.resource.data.totalAvailableRequests == 2
        && request.resource.data.resetPeriod == 'monthly'
        && request.resource.data.periodKey is string;
    }

    function isValidContactRequestCreate() {
      return isSignedIn()
        && request.resource.data.senderUserId == request.auth.uid
        && request.resource.data.receiverUserId is string
        && request.resource.data.receiverUserId != request.auth.uid
        && request.resource.data.targetUserId == request.resource.data.receiverUserId
        && request.resource.data.plateKey is string
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.isDeleted == false;
    }

    function isValidContactRequestAccept(requestId) {
      return resource.data.status == 'pending'
        && request.auth.uid == resource.data.receiverUserId
        && request.resource.data.status == 'accepted'
        && request.resource.data.chatId == 'request_' + requestId
        && request.resource.data.updatedAt is timestamp
        && changedOnly(['status', 'updatedAt', 'chatId']);
    }

    function isValidContactRequestDecline() {
      return resource.data.status == 'pending'
        && request.auth.uid == resource.data.receiverUserId
        && request.resource.data.status == 'declined'
        && request.resource.data.updatedAt is timestamp
        && changedOnly(['status', 'updatedAt']);
    }

    function isValidContactRequestWithdraw() {
      return resource.data.status == 'pending'
        && request.auth.uid == resource.data.senderUserId
        && request.resource.data.status == 'withdrawn'
        && request.resource.data.updatedAt is timestamp
        && changedOnly(['status', 'updatedAt']);
    }

    function isValidContactRequestUpdate(requestId) {
      return isSignedIn()
        && (
          isValidContactRequestAccept(requestId) ||
          isValidContactRequestDecline() ||
          isValidContactRequestWithdraw()
        );
    }

    function isValidChatCreateForRequest(chatId, requestId) {
      let contactRequest = get(/databases/$(database)/documents/contact_requests/$(requestId));

      return isSignedIn()
        && chatId == 'request_' + requestId
        && contactRequest.data.status == 'pending'
        && request.auth.uid == contactRequest.data.receiverUserId
        && request.resource.data.requestId == requestId
        && request.resource.data.status == 'active'
        && request.resource.data.isDeleted == false
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && contactRequest.data.senderUserId in request.resource.data.participants
        && contactRequest.data.receiverUserId in request.resource.data.participants
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          request.resource.data.lastMessage == null ||
          request.resource.data.lastMessage is string
        )
        && (
          request.resource.data.lastMessageAt == null ||
          request.resource.data.lastMessageAt is timestamp
        );
    }

    function isChatParticipant(chatId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidChatLastMessageUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants
        && changedOnly(['lastMessage', 'lastMessageAt', 'updatedAt'])
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() <= 1000
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidTextMessageCreate(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));

      return isSignedIn()
        && request.auth.uid in chat.data.participants
        && chat.data.status == 'active'
        && request.resource.data.chatId == chatId
        && request.resource.data.senderUserId == request.auth.uid
        && request.resource.data.type == 'text'
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.isDeleted == false;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;

      match /profiles/{profileId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if false;
      }

      match /search_credits/{creditId} {
        allow read: if isOwner(userId);
        allow create: if isValidInitialSearchCredit(userId, creditId);
        allow update, delete: if false;
      }

      match /legal_consents/{consentId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /moderation_actions/{actionId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    match /plates/{plateId} {
      allow read, list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.isActive == true
        && request.resource.data.isDeleted == false;

      allow update: if isSignedIn()
        && resource.data.ownerUserId == request.auth.uid
        && request.resource.data.ownerUserId == request.auth.uid;

      allow delete: if false;
    }

    match /contact_requests/{requestId} {
      allow read: if isSignedIn()
        && (
          resource.data.senderUserId == request.auth.uid ||
          resource.data.receiverUserId == request.auth.uid
        );

      allow create: if isValidContactRequestCreate();

      allow update: if isValidContactRequestUpdate(requestId);

      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if request.resource.data.requestId is string
        && isValidChatCreateForRequest(chatId, request.resource.data.requestId);

      allow update: if isValidChatLastMessageUpdate();

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);

        allow create: if isValidTextMessageCreate(chatId);

        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow read, update, delete: if false;

      allow create: if isSignedIn()
        && request.resource.data.reporterUserId == request.auth.uid;
    }

    match /verification_requests/{requestId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}